import os
import xxhash
import sqlite3
import tempfile
from collections import defaultdict
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path

# --- CONFIGURATION ---
PARTIAL_HASH_SIZE = 8192  # 8KB
FULL_HASH_CHUNK = 1024 * 1024  # 1MB
MAX_IO_THREADS = 32  # High thread count for I/O queue depth
DB_BATCH_SIZE = 10000  # SQLite write batch size


class FastDedupEngine:
    def __init__(self, directories, min_size=1024):
        self.directories = directories
        self.min_size = min_size
        
        # Setup temporary on-disk storage (automatically cleaned up later)
        self.temp_dir = tempfile.TemporaryDirectory()
        self.db_path = os.path.join(self.temp_dir.name, 'state.db')
        self.conn = sqlite3.connect(self.db_path)
        self._init_db()

    def _init_db(self):
        """Initializes the temporary SQLite database with high-performance PRAGMAs."""
        with self.conn:
            # PRAGMAs for maximum write speed to local temp storage
            self.conn.execute("PRAGMA journal_mode = WAL;")
            self.conn.execute("PRAGMA synchronous = OFF;")
            self.conn.execute("PRAGMA cache_size = -64000;") # 64MB cache limit
            self.conn.execute("""
                CREATE TABLE files (
                    path TEXT PRIMARY KEY,
                    size INTEGER,
                    partial_hash TEXT,
                    full_hash TEXT
                )
            """)
            # Index size immediately for Phase 1
            self.conn.execute("CREATE INDEX idx_size ON files(size);")

    def cleanup(self):
        """Closes the DB connection and removes the temporary files from the OS."""
        self.conn.close()
        self.temp_dir.cleanup()

    def run(self):
        try:
            print("Phase 1: Fast Size Discovery (Zero I/O)")
            self._populate_sizes()
            
            # Query the temp DB for files that share a size
            cursor = self.conn.cursor()
            cursor.execute("""
                SELECT path FROM files 
                WHERE size IN (
                    SELECT size FROM files GROUP BY size HAVING COUNT(*) > 1
                )
            """)
            paths_needing_partial = [row[0] for row in cursor.fetchall()]
            print(f"Filtered down to {len(paths_needing_partial)} files requiring partial hash.")

            if not paths_needing_partial:
                return {}

            print("Phase 2: Concurrent Partial Hashing")
            self._compute_partial_hashes(paths_needing_partial)
            
            # Create an index to speed up the duplicate partial hash query
            self.conn.execute("CREATE INDEX idx_partial ON files(partial_hash);")
            
            # Query the temp DB for files that share both size AND partial hash
            cursor.execute("""
                SELECT path FROM files 
                WHERE partial_hash IN (
                    SELECT partial_hash FROM files 
                    WHERE partial_hash IS NOT NULL 
                    GROUP BY size, partial_hash HAVING COUNT(*) > 1
                )
            """)
            paths_needing_full = [row[0] for row in cursor.fetchall()]
            print(f"Filtered down to {len(paths_needing_full)} files requiring full hash.")

            if not paths_needing_full:
                return {}

            print("Phase 3: Concurrent Full Hashing")
            self._compute_full_hashes(paths_needing_full)
            
            # Create final index
            self.conn.execute("CREATE INDEX idx_full ON files(full_hash);")
            
            # Extract final duplicate groups
            cursor.execute("""
                SELECT full_hash, path FROM files 
                WHERE full_hash IN (
                    SELECT full_hash FROM files 
                    WHERE full_hash IS NOT NULL 
                    GROUP BY full_hash HAVING COUNT(*) > 1
                )
            """)
            
            final_duplicates = defaultdict(list)
            for f_hash, path in cursor.fetchall():
                final_duplicates[f_hash].append(path)
                
            return dict(final_duplicates)
            
        finally:
            # Guarantee cleanup even if an error occurs or the user stops the script
            self.cleanup()

    def _populate_sizes(self):
        """Scans directories and writes file paths and sizes to temp DB in batches."""
        batch = []
        
        def scan_dir(path):
            try:
                with os.scandir(path) as it:
                    for entry in it:
                        if entry.is_file(follow_symlinks=False):
                            size = entry.stat().st_size
                            if size >= self.min_size:
                                batch.append((entry.path, size))
                                if len(batch) >= DB_BATCH_SIZE:
                                    self._flush_insert_batch(batch)
                        elif entry.is_dir(follow_symlinks=False):
                            scan_dir(entry.path)
            except PermissionError:
                pass # Gracefully handle unreadable directories

        for directory in self.directories:
            scan_dir(directory)
            
        if batch:
            self._flush_insert_batch(batch)

    def _flush_insert_batch(self, batch):
        with self.conn:
            self.conn.executemany(
                "INSERT OR IGNORE INTO files (path, size) VALUES (?, ?)", 
                batch
            )
        batch.clear()

    def _flush_update_batch(self, batch, column):
        with self.conn:
            self.conn.executemany(
                f"UPDATE files SET {column} = ? WHERE path = ?", 
                batch
            )
        batch.clear()

    def _hash_partial(self, filepath):
        """Reads only the first few KB of a file."""
        try:
            with open(filepath, 'rb') as f:
                chunk = f.read(PARTIAL_HASH_SIZE)
                return filepath, xxhash.xxh64(chunk).hexdigest()
        except OSError:
            return filepath, None

    def _compute_partial_hashes(self, paths):
        batch = []
        with ThreadPoolExecutor(max_workers=MAX_IO_THREADS) as executor:
            futures = {executor.submit(self._hash_partial, path): path for path in paths}
            for future in as_completed(futures):
                filepath, h_val = future.result()
                if h_val:
                    batch.append((h_val, filepath))  # Format: (value_to_set, where_path)
                    if len(batch) >= DB_BATCH_SIZE:
                        self._flush_update_batch(batch, "partial_hash")
        if batch:
            self._flush_update_batch(batch, "partial_hash")

    def _hash_full(self, filepath):
        """Hashes the entire file using large C-level chunks."""
        try:
            h = xxhash.xxh64()
            with open(filepath, 'rb') as f:
                while chunk := f.read(FULL_HASH_CHUNK):
                    h.update(chunk)
            return filepath, h.hexdigest()
        except OSError:
            return filepath, None

    def _compute_full_hashes(self, paths):
        batch = []
        with ThreadPoolExecutor(max_workers=MAX_IO_THREADS) as executor:
            futures = {executor.submit(self._hash_full, path): path for path in paths}
            for future in as_completed(futures):
                filepath, h_val = future.result()
                if h_val:
                    batch.append((h_val, filepath))
                    if len(batch) >= DB_BATCH_SIZE:
                        self._flush_update_batch(batch, "full_hash")
        if batch:
            self._flush_update_batch(batch, "full_hash")


